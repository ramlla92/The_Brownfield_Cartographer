    "sql::C:\\Users\\THINKPAD\\Desktop\\10_Academy_AI\\Week_4\\The_Brownfield_Cartographer\\_repos\\jaffle-shop\\models\\marts\\orders.sql": {
      "id": "sql::C:\\Users\\THINKPAD\\Desktop\\10_Academy_AI\\Week_4\\The_Brownfield_Cartographer\\_repos\\jaffle-shop\\models\\marts\\orders.sql",
