# ─────────────────────────────────────────────────────────────
# Brownfield Cartographer — Environment Configuration
# Copy this file to .env and fill in your actual API keys.
# NEVER commit .env to git.
# ─────────────────────────────────────────────────────────────

# LLM Providers (at least one required for Semanticist agent)
OPENAI_API_KEY=sk-...
GOOGLE_API_KEY=AIza...
ANTHROPIC_API_KEY=sk-ant-...

# OpenRouter (optional, for multi-model routing)
OPENROUTER_API_KEY=sk-or-...

# Model selection defaults
DEFAULT_FAST_MODEL=gemini-1.5-flash        # used for bulk Purpose Statements
DEFAULT_SYNTHESIS_MODEL=gemini-1.5-pro     # used for Day-One Q&A synthesis

# GitHub token (optional, for private repos or higher rate limits)
GITHUB_TOKEN=ghp_...

# Output directories (defaults shown — override if needed)
CARTOGRAPHY_OUTPUT_DIR=.cartography
SEMANTIC_INDEX_DIR=semantic_index

# Logging level: DEBUG | INFO | WARNING | ERROR
LOG_LEVEL=INFO
